<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StealthPane.ViewModels"
        x:Class="StealthPane.Views.WindowPickerWindow"
        x:DataType="vm:WindowPickerViewModel"
        Title="Select Window"
        Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBg}"
        CanResize="False">

  <Grid RowDefinitions="Auto,*,Auto" Margin="16">

    <!-- Header -->
    <TextBlock Grid.Row="0" Text="Select a window to capture"
               FontSize="13" FontWeight="SemiBold"
               Foreground="{StaticResource PrimaryFg}"
               Margin="0,0,0,12" />

    <!-- Window List -->
    <ListBox Grid.Row="1"
             ItemsSource="{Binding WindowTitles}"
             SelectedIndex="{Binding SelectedIndex}"
             Background="{StaticResource ControlBg}"
             Foreground="{StaticResource PrimaryFg}"
             BorderThickness="0"
             CornerRadius="4"
             DoubleTapped="OnListDoubleTapped" />

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel" FontSize="11" Height="28" MinWidth="80"
              Background="{StaticResource ControlBg}" Foreground="{StaticResource SecondaryFg}"
              BorderThickness="0"
              Command="{Binding CancelCommand}" />
      <Button Content="Select" FontSize="11" Height="28" MinWidth="80"
              Background="{StaticResource AccentBrush}" Foreground="White"
              BorderThickness="0"
              Command="{Binding SelectCommand}" />
    </StackPanel>

  </Grid>
</Window>
