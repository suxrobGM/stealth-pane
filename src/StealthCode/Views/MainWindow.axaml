<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StealthCode.ViewModels"
        xmlns:controls="using:StealthCode.Controls"
        x:Class="StealthCode.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.png"
        Title="Stealth Code"
        Width="900" Height="600"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="28"
        Background="{StaticResource WindowBg}"
        Topmost="{Binding IsAlwaysOnTop}"
        ShowInTaskbar="False"
        SystemDecorations="Full">

  <Grid RowDefinitions="28,*,20" ColumnDefinitions="*,Auto">

    <!-- Title Bar (acts as drag region) -->
    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource TitleBarBg}">
      <DockPanel>

        <!-- Right: Window controls -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,4,0">
          <Button Classes="chrome" Classes.pinned="{Binding IsAlwaysOnTop}"
                  Content="&#x2299;" FontSize="14"
                  Command="{Binding TogglePinCommand}" ToolTip.Tip="Toggle always on top" />
          <Button Classes="chrome" FontSize="16"
                  Command="{Binding ToggleSettingsCommand}" ToolTip.Tip="Settings">
            <TextBlock Text="&#x2261;" VerticalAlignment="Center" Margin="0,-2,0,0" />
          </Button>
          <Button Classes="chrome" Content="&#x2500;" FontSize="11"
                  Click="OnMinimizeClick" />
          <Button Classes="chrome" Content="&#x25A1;" FontSize="11"
                  Click="OnMaximizeClick" />
          <Button Classes="chrome" Content="&#x00D7;" FontSize="14"
                  Click="OnCloseClick" />
        </StackPanel>

        <!-- Left: App identity + Provider + Status -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="12,0,0,0"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Image Source="/Assets/logo-16.png" Width="14" Height="14" VerticalAlignment="Center" />
            <TextBlock Text="STEALTH CODE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TertiaryFg}" VerticalAlignment="Center" />
          </StackPanel>

          <ComboBox FontSize="11" Height="22" MinWidth="100"
                    Background="Transparent" Foreground="{StaticResource TertiaryFg}"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding ProviderNames}"
                    SelectedIndex="{Binding SelectedProviderIndex}" />

          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Opacity="0.6" />
            <TextBlock Text="PROTECTED" FontSize="10" Foreground="{StaticResource AccentBrush}"
                       Opacity="0.6" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- Terminal -->
    <controls:TerminalWebView Grid.Row="1" Grid.Column="0" x:Name="Terminal" />

    <!-- Settings Panel -->
    <ContentControl Grid.Row="1" Grid.Column="1"
                    IsVisible="{Binding IsSettingsVisible}"
                    Content="{Binding SettingsContent}" />

    <!-- Info Bar -->
    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource WindowBg}">
      <DockPanel Margin="12,0">
        <TextBlock DockPanel.Dock="Left" FontSize="10" Foreground="{StaticResource MutedFg}"
                   VerticalAlignment="Center"
                   Text="{Binding CaptureHotkeyText}" />
        <!-- Audio: show hotkey when model ready, REC when recording, download status otherwise -->
        <TextBlock DockPanel.Dock="Left" FontSize="10" Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource MutedFg}"
                   Text="{Binding Audio.HotkeyText}"
                   IsVisible="{Binding Audio.IsModelAvailable}" />
        <TextBlock DockPanel.Dock="Left" FontSize="10" Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource AccentBrush}"
                   Text="&#x23FA; REC"
                   IsVisible="{Binding Audio.IsRecording}" />
        <TextBlock DockPanel.Dock="Left" FontSize="10" Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource WarningFg}"
                   Text="{Binding Audio.StatusText}"
                   IsVisible="{Binding Audio.StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button FontSize="10" Foreground="{StaticResource AccentBrush}"
                  Content="UPDATE AVAILABLE" Cursor="Hand"
                  Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                  IsVisible="{Binding IsUpdateAvailable}"
                  Command="{Binding ShowUpdateCommand}" />
          <TextBlock FontSize="10" Foreground="{StaticResource MutedFg}"
                     Text="{Binding VersionText}" />
          <TextBlock FontSize="10" Foreground="{StaticResource MutedFg}"
                     Text="{Binding OpacityText}" />
        </StackPanel>
      </DockPanel>
    </Border>

  </Grid>
</Window>
