<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:StealthCode"
             x:Class="StealthCode.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Themes/Theme.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/logo.ico" ToolTipText="StealthCode">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Show" Click="OnTrayShow" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Exit" Click="OnTrayExit" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="/Themes/Styles.axaml" />
  </Application.Styles>
</Application>
