<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StealthPane.ViewModels"
             xmlns:controls="using:StealthPane.Controls"
             x:Class="StealthPane.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Width="300" Background="{StaticResource PanelBg}">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,12" Spacing="16">
      <!-- Header -->
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="Settings" FontSize="13"
                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryFg}"
                   VerticalAlignment="Center" />
        <Button Classes="chrome" DockPanel.Dock="Right" Content="&#x00D7;" FontSize="14"
                Width="28" HorizontalAlignment="Right"
                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleSettingsCommand}" />
      </DockPanel>

      <!-- General -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="GENERAL" />

        <StackPanel Spacing="4">
          <TextBlock Classes="field-label" Text="Provider" />
          <ComboBox Classes="form-input"
                    ItemsSource="{Binding ProviderNames}"
                    SelectedIndex="{Binding SelectedProviderIndex}" />
        </StackPanel>

        <StackPanel Spacing="4">
          <DockPanel>
            <TextBlock Classes="field-label" DockPanel.Dock="Left" Text="Opacity"
                       VerticalAlignment="Center" />
            <TextBlock Classes="field-label" DockPanel.Dock="Right"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Text="{Binding OpacityValueText}" />
          </DockPanel>
          <Slider Minimum="0.1" Maximum="1.0"
                  TickFrequency="0.05" IsSnapToTickEnabled="True"
                  Value="{Binding Opacity}" />
        </StackPanel>
      </StackPanel>

      <Border Classes="divider" />

      <!-- Capture -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="CAPTURE" />

        <StackPanel Spacing="4">
          <TextBlock Classes="field-label" Text="Mode" />
          <ComboBox Classes="form-input"
                    SelectedIndex="{Binding SelectedCaptureModeIndex}">
            <ComboBoxItem Content="Full Screen" />
            <ComboBoxItem Content="Region" />
            <ComboBoxItem Content="Window" />
          </ComboBox>
        </StackPanel>

        <!-- Region mode options -->
        <StackPanel Spacing="4" IsVisible="{Binding IsRegionMode}">
          <Button Content="Select Region" FontSize="11" Height="28"
                  Background="{StaticResource ControlBg}" Foreground="{StaticResource SecondaryFg}"
                  BorderThickness="0" HorizontalAlignment="Left"
                  Command="{Binding SelectRegionCommand}" />
          <TextBlock Classes="field-label" Text="{Binding RegionDisplayText}"
                     IsVisible="{Binding RegionDisplayText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- Window mode options -->
        <StackPanel Spacing="4" IsVisible="{Binding IsWindowMode}">
          <Button Content="Select Window" FontSize="11" Height="28"
                  Background="{StaticResource ControlBg}" Foreground="{StaticResource SecondaryFg}"
                  BorderThickness="0" HorizontalAlignment="Left"
                  Command="{Binding SelectWindowCommand}" />
          <TextBlock Classes="field-label" Text="{Binding SelectedWindowTitle}"
                     IsVisible="{Binding SelectedWindowTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Classes="field-label" Text="Capture Hotkey" />
          <controls:HotkeyTextBox Hotkey="{Binding Hotkey, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Classes="field-label" Text="Opacity Hotkey" />
          <controls:HotkeyTextBox Hotkey="{Binding OpacityHotkey, Mode=TwoWay}" />
        </StackPanel>
      </StackPanel>

      <Border Classes="divider" />

      <!-- System Prompt -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="SYSTEM PROMPT" />

        <TextBox Classes="form-input" Height="100"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Text="{Binding SystemPrompt}" />

        <Button Content="Reset to Default" FontSize="11" Height="26"
                Background="{StaticResource ControlBg}" Foreground="{StaticResource SecondaryFg}"
                BorderThickness="0" HorizontalAlignment="Left"
                Command="{Binding ResetPromptCommand}" />
      </StackPanel>

      <Border Classes="divider" />

      <!-- Cleanup -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="CLEANUP" />

        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Classes="field-label" Text="Auto-cleanup after"
                     VerticalAlignment="Center" />
          <NumericUpDown Classes="form-input" Width="100"
                         Minimum="5" Maximum="1440" Increment="5"
                         Value="{Binding CleanupMinutes}" />
          <TextBlock Classes="field-label" Text="min"
                     VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
