<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Title bar chrome button -->
  <Style Selector="Button.chrome">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource SecondaryFg}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Button.chrome.pinned">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>

  <!-- Section header -->
  <Style Selector="TextBlock.section-header">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="Foreground" Value="{StaticResource MutedFg}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- Field label -->
  <Style Selector="TextBlock.field-label">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource SecondaryFg}" />
  </Style>

  <!-- Horizontal divider -->
  <Style Selector="Border.divider">
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="{StaticResource DividerBrush}" />
  </Style>

  <!-- Form inputs -->
  <Style Selector="ComboBox.form-input">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Background" Value="{StaticResource ControlBg}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaryFg}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBox.form-input">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Background" Value="{StaticResource ControlBg}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaryFg}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="NumericUpDown.form-input">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Background" Value="{StaticResource ControlBg}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaryFg}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

</Styles>
